QDRANT_URL=
QDRANT_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Firebase project Web API key, used only by local token-generation tools.
FIREBASE_WEB_API_KEY=
VIDYALAYA_API_BASE_URL=http://localhost:8000

# Postgres connection (any Postgres: Supabase, Railway, local, ...).
# Use the plain postgres:// or postgresql:// URL from your provider; the app
# normalizes the driver internally (asyncpg for the app, psycopg for the
# LangGraph checkpointer). Example:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Supabase tip: use the "Connection string" -> "URI". For IPv4/poolers, the
# session pooler URL (port 5432) works; avoid the transaction pooler (6543)
# for the checkpointer since it needs prepared statements.
DATABASE_URL=

LEARNASSIST_DAILY_LIMIT=3

# Chat LLM selection (embeddings always use Gemini, set via GEMINI_API_KEY).
# LLM_PROVIDER: openrouter | google
LLM_PROVIDER=openrouter
# LLM_MODEL examples:
#   openrouter -> google/gemini-2.0-flash-001 | google/gemini-2.5-flash | openai/gpt-4.1-mini
#   google     -> gemini-2.5-flash | gemini-2.0-flash
LLM_MODEL=google/gemini-2.0-flash-001
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
LLM_REQUEST_TIMEOUT=60
OPENROUTER_API_KEY=
