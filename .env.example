QDRANT_URL=
QDRANT_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Firebase project Web API key, used only by local token-generation tools.
FIREBASE_WEB_API_KEY=
VIDYALAYA_API_BASE_URL=http://localhost:8000


DATABASE_URL=

LEARNASSIST_DAILY_LIMIT=3

# Chat LLM selection (embeddings always use Gemini, set via GEMINI_API_KEY).
# LLM_PROVIDER: openrouter | google
LLM_PROVIDER=openrouter
# LLM_MODEL examples:
#   openrouter -> google/gemini-2.5-flash | openai/gpt-4.1-mini
#   google     -> gemini-2.5-flash
LLM_MODEL=google/gemini-2.5-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
LLM_REQUEST_TIMEOUT=60
OPENROUTER_API_KEY=

# LearnAssist session memory reset.
# Auto-resets agent working memory after this many minutes of inactivity.
# Students can override this per-subject via PUT /me/preferences.
# Set to 0 to disable auto-reset globally (manual reset still works).
LEARNASSIST_SESSION_TIMEOUT_MINUTES=30
